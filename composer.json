{
  "name": "kazistm/algeria-geo",
  "description": "Algerian Cities (Wilayas) and Communes data package for Laravel.",
  "type": "laravel-package",
  "keywords": [
    "algeria", "wilaya", "city", "commune", "daira", "geo", "location", "laravel", "database", "seeder"
  ],
  "homepage": "https://github.com/KaziSTM/algeria-geo",
  "support": {
    "issues": "https://github.com/KaziSTM/algeria-geo/issues",
    "source": "https://github.com/KaziSTM/algeria-geo"
  },
  "license": "MIT",
  "authors": [
    {
      "name": "Youcef Nezrek",
      "email": "ynezrek@netgrid.dev"
    }
  ],
  "require": {
    "php": "^8.1|^8.2|^8.3",
    "illuminate/console": "^10.0|^11.0|^12.0",
    "illuminate/database": "^10.0|^11.0|^12.0",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/filesystem": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "pestphp/pest": "^2.0",
    "laravel/pint": "^1.13"
  },
  "autoload": {
    "psr-4": {
      "KaziSTM\\AlgeriaGeo\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "KaziSTM\\AlgeriaGeo\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "KaziSTM\\AlgeriaGeo\\AlgeriaGeoServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "./vendor/bin/pest",
    "lint": "./vendor/bin/pint"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}