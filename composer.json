{
  "name": "kazistm/algeria-geo",
  "description": "Laravel package providing complete Algerian geo data (69 Wilayas and Communes) with slugs, coordinates and optimized seeders.",
  "type": "laravel-package",
  "keywords": [
    "algeria",
    "wilaya",
    "69 wilayas",
    "communes",
    "daira",
    "algeria geo",
    "algeria locations",
    "laravel",
    "laravel geo",
    "laravel seeder",
    "database seeder",
    "geolocation",
    "coordinates",
    "algerian cities"
  ],
  "homepage": "https://github.com/KaziSTM/algeria-geo",
  "support": {
    "issues": "https://github.com/KaziSTM/algeria-geo/issues",
    "source": "https://github.com/KaziSTM/algeria-geo"
  },
  "license": "MIT",
  "authors": [
    {
      "name": "Youcef Nezrek",
      "email": "ynezrek@netgrid.dev"
    }
    ],

    "require": {
      "php": "^8.1 || ^8.2 || ^8.3 || ^8.4 || ^8.5",
      "illuminate/console": "^10.0 || ^11.0 || ^12.0 || ^13.0",
      "illuminate/database": "^10.0 || ^11.0 || ^12.0 || ^13.0",
      "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
      "illuminate/filesystem": "^10.0 || ^11.0 || ^12.0 || ^13.0",
      "spatie/laravel-package-tools": "^1.16"
    },

  "require-dev": {
    "laravel/pint": "^1.13",
    "nunomaduro/collision": "^7.0 || ^8.0",
    "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
    "pestphp/pest": "^2.0 || ^3.0",
    "pestphp/pest-plugin-laravel": "^2.0 || ^3.0"
  },

    "autoload": {
      "psr-4": {
        "KaziSTM\\AlgeriaGeo\\": "src/"
      }
    },

    "autoload-dev": {
      "psr-4": {
        "KaziSTM\\AlgeriaGeo\\Tests\\": "tests/"
      }
    },

    "extra": {
      "laravel": {
        "providers": [
          "KaziSTM\\AlgeriaGeo\\AlgeriaGeoServiceProvider"
        ]
      },
      "branch-alias": {
        "dev-main": "1.x-dev"
      }
    },

    "scripts": {
      "test": "pest",
      "test:coverage": "pest --coverage",
      "lint": "pint"
    },

    "config": {
      "sort-packages": true,
      "allow-plugins": {
        "pestphp/pest-plugin": true
      }
    },

    "minimum-stability": "stable",
    "prefer-stable": true
    }
